{
  "name": "xshow",
  "version": "0.3.0-alpha.0",
  "description": "Interactive electronic brick circuit playground built with Vue 3, Vite, TypeScript, and Tailwind CSS.",
  "private": true,
  "type": "module",
  "keywords": [
    "vue",
    "vite",
    "typescript",
    "tailwindcss",
    "circuit",
    "electronics",
    "education",
    "simulation"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test tests/*.mjs",
    "test:simulation": "node --test tests/simulation.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
